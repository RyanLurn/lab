{
  "name": "lab",
  "type": "module",
  "private": true,
  "scripts": {
    "format": "bunx prettier . --write --cache",
    "format:check": "bunx prettier . --check --cache"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "configs/*",
      "packages/*",
      "scripts/*"
    ],
    "catalog": {
      "eslint": "^10.1.0",
      "typescript": "^6.0.2"
    },
    "catalogs": {
      "types": {
        "@types/bun": "^1.3.11"
      }
    }
  },
  "devDependencies": {
    "prettier": "3.8.1"
  },
  "packageManager": "bun@1.3.11"
}
