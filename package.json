{
  "name": "lab",
  "type": "module",
  "private": true,
  "scripts": {
    "check-types": "bun run --parallel --workspaces --if-present --no-exit-on-error check-types",
    "lint": "bun run --parallel --workspaces --if-present --no-exit-on-error lint",
    "lint:fix": "bun run --parallel --workspaces --if-present --no-exit-on-error lint:fix",
    "format": "bunx prettier . --write --cache",
    "format:check": "bunx prettier . --check --cache",
    "check": "bun run check-types && bun run lint && bun run format:check",
    "core:build": "bun --filter @lab/core build --log-level error",
    "ui:build": "bun --filter @lab/ui build --log-level error"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "axon/*",
      "configs/*",
      "packages/*",
      "scripts/*"
    ],
    "catalog": {
      "@tanstack/react-router": "^1.168.10",
      "eslint": "^10.1.0",
      "hono": "^4.12.9",
      "typescript": "^6.0.2",
      "zod": "^4.3.6"
    },
    "catalogs": {
      "types": {
        "@types/babel__core": "^7.20.5",
        "@types/bun": "^1.3.10",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3"
      },
      "ui": {
        "lucide-react": "^1.7.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.2"
      },
      "build": {
        "@babel/core": "^7.29.0",
        "@rolldown/plugin-babel": "^0.2.2",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/router-plugin": "^1.167.12",
        "@vitejs/plugin-react": "^6.0.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "tsdown": "^0.21.7",
        "vite": "^8.0.3"
      }
    }
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2"
  },
  "packageManager": "bun@1.3.11"
}
