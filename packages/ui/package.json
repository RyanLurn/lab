{
  "name": "@lab/ui",
  "type": "module",
  "private": true,
  "exports": {
    "./*": {
      "import": "./dist/*.mjs",
      "types": "./dist/*.d.mts"
    },
    "./style.css": "./src/globals.css"
  },
  "scripts": {
    "build": "bunx tsdown",
    "build:watch": "bunx tsdown --watch",
    "check-types": "bunx tsc --noEmit",
    "lint": "bunx eslint --cache",
    "lint:fix": "bunx eslint --cache --fix",
    "check": "bun run check-types && bun run lint",
    "shadcn:add": "bunx --bun shadcn add"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "lucide-react": "catalog:ui",
    "react": "catalog:ui",
    "react-dom": "catalog:ui",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lab/eslint": "workspace:*",
    "@lab/typescript": "workspace:*",
    "@types/bun": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "eslint": "catalog:",
    "shadcn": "^4.1.1",
    "tailwindcss": "catalog:ui",
    "tsdown": "catalog:build",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:"
  }
}
